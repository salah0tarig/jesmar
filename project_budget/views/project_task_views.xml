<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_project_task_form_budget" model="ir.ui.view">
        <field name="name">project.task.form.budget</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='project_id']" position="after">
                <field name="parent_account_id" invisible="1"/>
                <field name="outcome_id" options="{'no_create': True}"/>
                <field name="output_id" options="{'no_create': True}"/>
                <field name="activity_analytic_account_id" options="{'no_create': True}"
                       string="Activity Analytic Account"/>
            </xpath>
        </field>
    </record>
</odoo>
